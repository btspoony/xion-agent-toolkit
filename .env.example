# Xion OAuth2 Client IDs
# Copy this file to .env and fill in the actual values
# Note: Local and Testnet may use the same client ID for development convenience

# Local development OAuth2 client ID
XION_LOCAL_OAUTH_CLIENT_ID=your-local-client-id-here

# Testnet OAuth2 client ID (often same as local for development)
XION_TESTNET_OAUTH_CLIENT_ID=your-testnet-client-id-here

# Mainnet OAuth2 client ID
XION_MAINNET_OAUTH_CLIENT_ID=your-mainnet-client-id-here
